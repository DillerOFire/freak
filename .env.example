[.env.example#DD3B]
1:# Copy to .env and fill in secrets:
2:#   cp .env.example .env
3:
4:# Required
5:TELEGRAM_BOT_TOKEN=
6:OPENROUTER_API_KEY=
7:ADMIN_ID=123456789
8:
9:# Main chat model (persona replies, reactions, memory tool routing)
10:OPENROUTER_MODEL=google/gemini-flash-2.5
11:
12:# Sandboxed ponder / research agent (web search, page fetch, memory recall)
13:OPENROUTER_PONDER_MODEL=deepseek/deepseek-v4-flash
14:
15:# Vision (image / video frame analysis)
16:OPENROUTER_VISION_MODEL=google/gemini-flash-2.5
17:
18:# OpenRouter attribution (optional)
19:OPENROUTER_REFERER=https://github.com/DillerOFire/freak
20:OPENROUTER_TITLE=Freaky tg bot
21:
22:# Writable yt-dlp overlay when the venv is not upgradeable (Docker default: /data/python-packages)
# YTDLP_PACKAGE_DIR=/data/python-packages

# Telemetry dashboard (optional)
23:TELEMETRY_DASHBOARD_ENABLED=true
24:TELEMETRY_DASHBOARD_HOST=127.0.0.1
25:TELEMETRY_DASHBOARD_PORT=8765
26:# TELEMETRY_DASHBOARD_TOKEN=
27:
28:# Self-update helpers (optional; used when systemd PATH omits ~/.local/bin)
29:# UV_EXECUTABLE=/home/you/.local/bin/uv
30: