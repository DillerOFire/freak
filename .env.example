# Copy to .env and fill in secrets:
#   cp .env.example .env
#
# Docker: compose sets ENV_FILE=/data/.env (persisted on the ./data volume).
# The bot seeds that file on first run; use /bot_env and /set_env in a DM to edit keys.

# Required
TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=
ADMIN_ID=123456789

# Main chat model (persona replies, reactions, memory tool routing)
OPENROUTER_MODEL=google/gemini-flash-2.5

# Sandboxed ponder / research agent (web search, page fetch, memory recall)
OPENROUTER_PONDER_MODEL=deepseek/deepseek-v4-flash

# Vision (image / video frame analysis)
OPENROUTER_VISION_MODEL=google/gemini-flash-2.5

# OpenRouter attribution (optional)
OPENROUTER_REFERER=https://github.com/DillerOFire/freak
OPENROUTER_TITLE=Freaky tg bot

# Writable yt-dlp overlay when the venv is not upgradeable (Docker default: /data/python-packages)
# YTDLP_PACKAGE_DIR=/data/python-packages

# Telemetry dashboard (optional)
TELEMETRY_DASHBOARD_ENABLED=true
TELEMETRY_DASHBOARD_HOST=127.0.0.1
TELEMETRY_DASHBOARD_PORT=8765
# TELEMETRY_DASHBOARD_TOKEN=

# Self-update helpers (optional; used when systemd PATH omits ~/.local/bin)
# UV_EXECUTABLE=/home/you/.local/bin/uv
